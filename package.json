{
	"name": "package.json",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "run-p type-check \"build-only {@}\" --",
		"preview": "vite preview",
		"build-only": "vite build",
		"type-check": "vue-tsc --build",
		"lint": "eslint src/ --ext .vue,.ts,.js --fix --cache",
		"format": "prettier --write src/",
		"prepare": "husky",
		"check": "npm run lint && npm run format",
		"commit": "npm run check && cz"
	},
	"config": {
		"commitizen": {
			"path": "./node_modules/cz-conventional-changelog"
		}
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,vue}": [
			"eslint --fix --cache",
			"prettier --write"
		],
		"*.{json,css,scss,md}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"pinia": "^3.0.4",
		"vue": "^3.5.24",
		"vue-router": "^5.0.2"
	},
	"devDependencies": {
		"@types/node": "^24.10.1",
		"@vitejs/plugin-vue": "^6.0.1",
		"@vue/eslint-config-prettier": "^10.2.0",
		"@vue/eslint-config-typescript": "^14.6.0",
		"@vue/tsconfig": "^0.8.1",
		"commitizen": "^4.3.1",
		"eslint": "^9.39.2",
		"eslint-plugin-vue": "^10.7.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"postcss": "^8.5.6",
		"postcss-pxtorem": "^6.1.0",
		"prettier": "^3.8.1",
		"sass": "^1.97.3",
		"typescript": "~5.9.3",
		"vite": "npm:rolldown-vite@7.2.5",
		"vue-tsc": "^3.1.4"
	},
	"overrides": {
		"vite": "npm:rolldown-vite@7.2.5"
	}
}
